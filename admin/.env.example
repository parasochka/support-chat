# Base URL of the FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8080

# Optional: a pre-issued admin JWT (from POST /admin/login). When set, the SPA
# skips the login form and sends this token as `Authorization: Bearer <token>`.
# Leave empty in normal deployments — admins log in with email + password.
VITE_ADMIN_TOKEN=
