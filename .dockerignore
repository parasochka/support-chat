.git
.gitignore
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
tests/
# Admin SPA: sources are copied into the node build stage; local artifacts and
# env files must never leak into either stage.
admin/node_modules/
admin/dist/
admin/.env
admin/.env.local
# Local retention media uploads never belong in the image (real media lives on
# the Railway Volume mounted at RETENTION_MEDIA_DIR).
media/
# Keep .md out of the image EXCEPT the docs the app renders at runtime:
# main.py reads CLAUDE.md on every request to render the root test page, and
# README.md is its byte-identical mirror. Excluding them left the <pre> block
# empty in production (CLAUDE.md was never in the image).
*.md
!CLAUDE.md
!README.md
